<div id="marco">
  <h1><span class="cabezatext">Establecer Nueva Contraseña</span></h1>
  <h6><span class="otrostext">Ingresa tu nueva contraseña a continuación.</span></h6>

  {{!-- Mensaje de error --}}
  {{#if error}}
    <div style="background-color:#ffcccc; color:#8b0000; padding:10px; border-radius:8px; margin-bottom:15px; text-align:center;">
      {{error}}
    </div>
  {{/if}}

  <form id="reset-form" method="post" action="/reset-password">
    <input type="hidden" name="correo" value="{{correo}}"> 
    
    <input
      type="password"
      name="nuevaContraseña"
      class="inputs"
      placeholder="Nueva Contraseña"
      required
    />
    <input
      type="password"
      name="confirmarContraseña"
      class="inputs"
      placeholder="Confirmar Nueva Contraseña"
      required
    />
    <input
      type="submit"
      value="Guardar Contraseña"
      class="inputs submit"
    />
    <br><br>
    <a href="/login" class="left">Volver a Iniciar Sesión</a>
  </form>
</div>