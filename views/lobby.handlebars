<div class="links">
    <a href="/transacciones">Recarga y retiro</a>
    <a href="/perfil">Ver Perfil</a>
</div>

<div class="upleft">
    <a href="/">Volver al inicio</a>
</div>

<main class="pagina-lobby">
    <h1>Mesa de Ruleta Europea</h1>

    <section class="mesa-ruleta">
      <div id="ruleta-container">
        <svg id="ruleta-svg" viewBox="0 0 200 200">
          <g id="ruleta-giratoria" transform-origin="100 100">
            <circle cx="100" cy="100" r="98" fill="#2c3e50"/>
            <circle cx="100" cy="100" r="90" fill="#34495e"/>
            <circle cx="100" cy="100" r="20" fill="#1c2833"/>
          </g>
          <polygon points="95,5 105,5 100,15" fill="#e74c3c"/>
        </svg>
      </div>
        
      <div class="controles-juego">
          <p id="mensaje-juego">Selecciona un número y un monto para apostar</p>
          <div class="saldo-display">Saldo actual: <strong id="saldo-actual">{{saldo}} fichas</strong></div>
          <input type="number" id="monto-apuesta" placeholder="Monto de la apuesta">
          <button id="btn-girar">Girar la Ruleta</button>
      </div>
    </section>

    <section id="mesa-de-apuestas">
      <div class="numero-apuesta verde" data-numero="0">0</div>
      <div id="numeros-grid">
        </div>
      <div id="apuestas-externas">
        <div class="apuesta-externa apuesta-rojo" data-bet="rojo">ROJO</div>
        <div class="apuesta-externa apuesta-negro" data-bet="negro">NEGRO</div>
      </div>
    </section>

    <section class="ganadores">
        <h2>Últimos 5 números ganadores</h2>
        <ul id="lista-ganadores"></ul>
    </section>

    <section class="apuestas">
        <h2>Últimas 5 apuestas</h2>
        <table>
            <thead>
                <tr><th>Usuario</th><th>Tipo</th><th>Monto</th><th>Resultado</th><th>Variación</th></tr>
            </thead>
            <tbody id="tabla-apuestas-body"></tbody>
        </table>
    </section>
</main>

<script id="initial-data" type="application/json">
    {
        "historialGanadores": {{{historialGanadores}}},
        "historialApuestas": {{{historialApuestas}}},
        "usertag": "{{usertag}}"
    }
</script>

<script>
  document.body.classList.add('pagina-larga');
</script>

{{#section 'scripts'}}
  <script src="/js/ruleta.js"></script>
{{/section}}